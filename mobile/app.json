{
  "expo": {
    "name": "Kinevo",
    "slug": "kinevo",
    "version": "1.5.0",
    "orientation": "default",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "dark",
    "newArchEnabled": true,
    "scheme": "kinevo",
    "splash": {
      "image": "./assets/splash-v2.png",
      "resizeMode": "contain",
      "backgroundColor": "#111019"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.kinevo.mobile",
      "buildNumber": "31",
      "appleTeamId": "3D5M22J52M",
      "entitlements": {
        "com.apple.developer.healthkit": true,
        "aps-environment": "production"
      },
      "infoPlist": {
        "UISupportedInterfaceOrientations~ipad": [
          "UIInterfaceOrientationPortrait",
          "UIInterfaceOrientationPortraitUpsideDown",
          "UIInterfaceOrientationLandscapeLeft",
          "UIInterfaceOrientationLandscapeRight"
        ],
        "UIBackgroundModes": [
          "remote-notification",
          "fetch"
        ],
        "ITSAppUsesNonExemptEncryption": false,
        "NSSupportsLiveActivities": true
      }
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#111019"
      },
      "package": "com.kinevo.mobile",
      "googleServicesFile": "./google-services.json",
      "edgeToEdgeEnabled": true,
      "permissions": [
        "android.permission.RECORD_AUDIO",
        "android.permission.POST_NOTIFICATIONS",
        "android.permission.health.READ_SLEEP",
        "android.permission.health.READ_STEPS",
        "android.permission.health.READ_HEART_RATE",
        "android.permission.health.READ_HEART_RATE_VARIABILITY",
        "android.permission.health.READ_RESTING_HEART_RATE",
        "android.permission.health.READ_ACTIVE_CALORIES_BURNED",
        "android.permission.health.READ_DISTANCE"
      ]
    },
    "web": {
      "favicon": "./assets/favicon.png",
      "bundler": "metro"
    },
    "plugins": [
      "expo-router",
      "expo-secure-store",
      "expo-web-browser",
      [
        "expo-image-picker",
        {
          "photosPermission": "O Kinevo precisa de acesso à sua galeria para você alterar sua foto de perfil."
        }
      ],
      [
        "expo-notifications",
        {
          "icon": "./assets/adaptive-icon.png",
          "color": "#7c3aed"
        }
      ],
      "@bacons/apple-targets",
      "./plugins/with-watch-app",
      [
        "@kingstinct/react-native-healthkit",
        {
          "NSHealthShareUsageDescription": "O Kinevo le seus dados de saude (sono, passos, frequencia cardiaca, HRV) pra mostrar suas tendencias de saude e personalizar seu coaching. Voce controla quais categorias compartilhar nos Ajustes do Kinevo.",
          "NSHealthUpdateUsageDescription": "O Kinevo salva seus treinos no Apple Saude como exercicio de forca.",
          "background": true
        }
      ],
      "react-native-health-connect",
      [
        "expo-build-properties",
        {
          "android": {
            "buildArchs": ["arm64-v8a", "armeabi-v7a"]
          }
        }
      ]
    ],
    "extra": {
      "router": {},
      "eas": {
        "build": {
          "experimental": {
            "ios": {
              "appExtensions": [
                {
                  "bundleIdentifier": "com.kinevo.mobile.WorkoutActivity",
                  "targetName": "WorkoutActivity"
                },
                {
                  "bundleIdentifier": "com.kinevo.mobile.watchkitapp",
                  "targetName": "KinevoWatch"
                }
              ]
            }
          }
        },
        "projectId": "3bfbd791-f08d-4df0-96db-eed6cde4275a"
      }
    },
    "owner": "gustavocprado"
  }
}